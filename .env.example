APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_VERSION=1.0.6
APP_TIMEZONE=America/Chicago
APP_KEY=change-this-to-a-random-64-char-string
ENTRY_UID_APP_VERSION_CODE=W010000

# If MySQL is on the same machine as Docker engine, you can use:
# DB_HOST=host.docker.internal
# If Docker engine is remote, set DB_HOST to a network-reachable DB hostname/IP.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rjournaler_web
DB_USER=rjournaler
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

SESSION_NAME=rjournaler_session
SESSION_LIFETIME_MINUTES=120
SESSION_SECURE_COOKIE=false
SESSION_SAMESITE=Strict

TRUSTED_DEVICE_DAYS=30
TOTP_ISSUER=rJournaler Web

WORKER_POLL_SECONDS=3
WORKER_INSTANCE_NAME=worker-1
QUEUE_COMPLETE_RETENTION_HOURS=168
QUEUE_FAILED_RETENTION_HOURS=168
AUTO_FINISH_HOUR_LOCAL=1
OLLAMA_URL=http://10.0.0.65:11435
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_REQUIRED=false
OLLAMA_RETRY_SECONDS=120

OPTIMUS_MAX_AUTOBOTS=4
AUTOBOT_MAX_PER_TYPE_DEFAULT=1
AUTOBOT_IDLE_LIFETIME_MINUTES=5

PIPELINE_CONFIG_PATH=python/worker/pipeline_stages.json
PIPELINE_PROMPT_DIR=python/worker/prompts
